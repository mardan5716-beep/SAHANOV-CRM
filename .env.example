# Строка подключения к PostgreSQL.
# Локально (docker-compose) — порт 5434:
DATABASE_URL="postgresql://crm:crm@localhost:5434/crm?schema=public"
# Для Neon строка выглядит так:
# DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# Секрет для подписи cookie-сессии (минимум 32 символа, любые случайные символы).
# Сгенерировать: openssl rand -hex 32
SESSION_SECRET="dev-secret-change-in-production-please-32chars-min"

# Вход в систему — по email и паролю менеджера (создаются через seed или на
# странице «Менеджеры»). Первый админ из seed: admin@glint.kz / changeme.
